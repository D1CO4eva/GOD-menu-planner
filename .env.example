# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Auth service endpoint that proxies menu writes/reads to Apps Script.
# Example deployed: https://god-auth-service-693007788010.us-central1.run.app/api/menu
VITE_MENU_API_URL="https://god-auth-service-693007788010.us-central1.run.app/api/menu"

# Optional explicit Auth service endpoint for LLM generation proxy.
# If omitted, app derives /generate (and /api/generate) from VITE_MENU_API_URL.
VITE_MENU_GENERATE_API_URL="https://god-auth-service-693007788010.us-central1.run.app/generate"
